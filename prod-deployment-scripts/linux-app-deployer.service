[Unit]
Description=Linux Application Deployer (API + MCP Server)
After=network.target nginx.service
Requires=nginx.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/mcp/linux-app-deployer
ExecStart=/opt/mcp/linux-app-deployer/prod-deployment-scripts/start.sh

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target